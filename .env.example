# Runtime network config
# Platform-provided PORT should take precedence in production.
APP_PORT=8080
CSS_PORT=3000
HOST=0.0.0.0

# Local Solid account bootstrap. Change the password before first start.
CSS_ACCOUNT_EMAIL=alice@example.test
CSS_ACCOUNT_PASSWORD=replace-with-a-long-local-password
CSS_POD_NAME=alice

# Solid/CSS config (replace for your environment).
# NOTE: URLs below use the literal default port values.
# If you change APP_PORT or CSS_PORT above, update these URLs to match.
SOLID_POD_SERVER_URL=http://localhost:3000
SOLID_OIDC_ISSUER=http://localhost:3000
SOLID_POD_PATH=/health-pim/
SOLID_REDIRECT_URL=http://localhost:8080/callback
