# ─── OpenCommons Health PIM – environment variables ──────────────────────────
#
# Copy this file to .env and fill in your values before running the app or
# integration tests.
#
#   cp .env.example .env
#
# The .env file is gitignored. Never commit real credentials.

# ── Solid Community Server ────────────────────────────────────────────────────

# Base URL of your local CSS instance.
CSS_URL=http://localhost:3000

# User's pod base URL (usually CSS_URL/<username>/).
POD_BASE_URL=http://localhost:3000/alice/

# Sub-path within the pod where PIM data is stored.
POD_PATH=/health-pim/

# ── Client Credentials (headless / server-to-server) ─────────────────────────
# Obtain these from the CSS admin interface or provisioning script.

CSS_CLIENT_ID=
CSS_CLIENT_SECRET=

# ── Integration tests ─────────────────────────────────────────────────────────
# Set these to run `npm run test:integration` against a live CSS endpoint.

INTEGRATION_TEST_BASE_URL=http://localhost:3000
INTEGRATION_POD_BASE_URL=http://localhost:3000/alice/
INTEGRATION_CLIENT_ID=
INTEGRATION_CLIENT_SECRET=
