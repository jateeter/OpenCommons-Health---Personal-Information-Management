# Runtime network config
# APP_PORT and CSS_PORT are the source of truth for local deployment scripts.
# Platform-provided PORT still takes precedence in production app containers.
APP_PORT=8080
CSS_PORT=3000
HOST=0.0.0.0

# Local Solid account bootstrap. Change the password before first start.
CSS_ACCOUNT_EMAIL=alice@example.test
CSS_ACCOUNT_PASSWORD=replace-with-a-long-local-password
CSS_POD_NAME=alice

# Solid/CSS config (replace for your environment).
# Docker Compose derives the container deployment URLs from APP_PORT, CSS_PORT,
# and CSS_POD_NAME. Host-local mode writes .solid/host-local.env with matching
# localhost URLs when you run ./scripts/local-host-solid-up.sh.
#
# Use these direct values only when running npm start without the host-local
# helper scripts.
SOLID_POD_SERVER_URL=http://localhost:3000
SOLID_OIDC_ISSUER=http://localhost:3000
SOLID_POD_PATH=/health-pim/
SOLID_REDIRECT_URL=http://localhost:8080/callback
