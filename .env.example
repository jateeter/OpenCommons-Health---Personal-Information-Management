# Runtime network config
# APP_PORT and CSS_PORT are the source of truth for local deployment scripts.
# Platform-provided PORT still takes precedence in production app containers.
APP_PORT=8080
CSS_PORT=3000
HOST=0.0.0.0

# Local Solid account bootstrap. Change the password before first start.
CSS_ACCOUNT_EMAIL=alice@example.test
CSS_ACCOUNT_PASSWORD=replace-with-a-long-local-password
CSS_POD_NAME=alice

# Solid/CSS config (replace for your environment).
# Docker Compose derives the container deployment URLs from APP_PORT, CSS_PORT,
# and CSS_POD_NAME. Host-local mode writes .solid/host-local.env with matching
# localhost URLs when you run ./scripts/local-host-solid-up.sh.
#
# Use these direct values only when running npm start without the host-local
# helper scripts.
SOLID_POD_SERVER_URL=http://localhost:3000
SOLID_OIDC_ISSUER=http://localhost:3000
SOLID_POD_PATH=/health-pim/
SOLID_REDIRECT_URL=http://localhost:8080/callback

# Epic SMART/FHIR MVP integration.
# Disabled by default so local Solid-only deployments remain the default happy
# path. Mock mode provides deterministic local/docker E2E data without real Epic
# credentials. Sandbox/production require values registered with Epic.
EPIC_ENABLED=false
EPIC_MODE=mock
EPIC_FHIR_BASE_URL=
EPIC_CLIENT_ID=
# Optional. Use only if your Epic app registration is confidential or your
# Epic customer configuration requires a client secret for refresh tokens.
EPIC_CLIENT_SECRET=
EPIC_CLIENT_SECRET_FILE=
EPIC_REDIRECT_URI=http://localhost:8080/api/integrations/epic/connect/callback
EPIC_GRANT_ENCRYPTION_KEY=replace-with-a-long-local-epic-grant-key
EPIC_SYNC_ON_STARTUP=false
# Override only when narrowing the MVP scope set.
# EPIC_SCOPES=openid fhirUser launch/patient offline_access patient/Patient.rs patient/Condition.rs patient/MedicationRequest.rs patient/MedicationStatement.rs patient/AllergyIntolerance.rs patient/Immunization.rs patient/Observation.rs patient/DiagnosticReport.rs patient/Coverage.rs patient/DocumentReference.rs
