import { useEffect, useState } from "react";
import { BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer } from "recharts";

type Cfg = any;

export default function App() {
  const [cfg, setCfg] = useState<Cfg | null>(null);
  const [solid, setSolid] = useState<any>(null);

  async function load() {
    setCfg(await fetch("/api/config").then(r => r.json()));
    setSolid(await fetch("/api/solid/health").then(r => r.json()));
  }

  useEffect(() => { load(); }, []);

  async function save() {
    await fetch("/api/config", { method: "PUT", headers: { "content-type": "application/json" }, body: JSON.stringify(cfg) });
    await load();
  }

  if (!cfg) return <div style={{padding:20}}>Loading…</div>;

  const chartData = [
    { name: "localSolidCommunityServer", value: cfg.localSolidCommunityServer ? 1 : 0 },
    { name: "solidHealth", value: solid?.ok ? 1 : 0 }
  ];

  return (
    <div style={{fontFamily:"sans-serif", padding:20}}>
      <h1>OpenCommons Health Config</h1>
      <label>
        <input type="checkbox" checked={!!cfg.localSolidCommunityServer}
          onChange={e => setCfg({...cfg, localSolidCommunityServer: e.target.checked})}/>
        localSolidCommunityServer
      </label>
      <div>
        <input value={cfg.SOLID_POD_SERVER_URL} onChange={e => setCfg({...cfg, SOLID_POD_SERVER_URL:e.target.value})} style={{width:500}} />
      </div>
      <button onClick={save}>Save</button>
      <pre>{JSON.stringify({solid}, null, 2)}</pre>
      <div style={{width:500, height:240}}>
        <ResponsiveContainer>
          <BarChart data={chartData}><XAxis dataKey="name"/><YAxis domain={[0,1]}/><Tooltip/><Bar dataKey="value"/></BarChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}
EOF

