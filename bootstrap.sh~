cat > backend/src/config/store.ts <<'EOF'
import fs from "node:fs";
import path from "node:path";
import { ConfigSchema, type AppConfig } from "./schema.js";

const CONFIG_FILE_PATH = process.env.CONFIG_FILE_PATH || "/tmp/config.json";

function fromEnv(): AppConfig {
  return ConfigSchema.parse({
    HOST: process.env.HOST ?? "0.0.0.0",
    PORT: process.env.PORT ?? 8080,
    APP_PORT: process.env.APP_PORT ?? 8080,
    localSolidCommunityServer: process.env.localSolidCommunityServer ?? true,
    SOLID_POD_SERVER_URL: process.env.SOLID_POD_SERVER_URL ?? "http://local-solid-community-server:3000",
    SOLID_OIDC_ISSUER: process.env.SOLID_OIDC_ISSUER ?? "http://local-solid-community-server:3000",
    SOLID_POD_PATH: process.env.SOLID_POD_PATH ?? "/pods",
    SOLID_REDIRECT_URL: process.env.SOLID_REDIRECT_URL ?? "https://localhost/auth/callback"
  });
}

export function loadConfig(): AppConfig {
  if (!fs.existsSync(CONFIG_FILE_PATH)) return fromEnv();
  const raw = fs.readFileSync(CONFIG_FILE_PATH, "utf-8");
  return ConfigSchema.parse(JSON.parse(raw));
}

export function saveConfig(input: unknown): AppConfig {
  const parsed = ConfigSchema.parse(input);
  fs.mkdirSync(path.dirname(CONFIG_FILE_PATH), { recursive: true });
  fs.writeFileSync(CONFIG_FILE_PATH, JSON.stringify(parsed, null, 2));
  return parsed;
}
EOF

cat > backend/src/index.ts <<'EOF'
import "dotenv/config";
import express from "express";
import cors from "cors";
import { loadConfig, saveConfig } from "./config/store.js";

const app = express();
app.use(cors());
app.use(express.json());

app.get("/api/healthz", (_req, res) => {
  res.json({ ok: true, service: "backend" });
});

app.get("/api/config", (_req, res) => {
  res.json(loadConfig());
});

app.put("/api/config", (req, res) => {
  try {
    res.json(saveConfig(req.body));
  } catch (e: any) {
    res.status(400).json({ ok: false, error: e.message });
  }
});

app.get("/api/solid/health", async (_req, res) => {
  const cfg = loadConfig();
  if (!cfg.localSolidCommunityServer) return res.json({ ok: true, enabled: false });
  try {
    const ctrl = new AbortController();
    const t = setTimeout(() => ctrl.abort(), 3000);
    const r = await fetch(cfg.SOLID_POD_SERVER_URL, { signal: ctrl.signal });
    clearTimeout(t);
    res.json({ ok: r.ok, enabled: true, status: r.status, url: cfg.SOLID_POD_SERVER_URL });
  } catch {
    res.status(503).json({ ok: false, enabled: true, url: cfg.SOLID_POD_SERVER_URL });
  }
});

const port = Number(process.env.BACKEND_PORT || 3001);
app.listen(port, "0.0.0.0", () => {
  console.log(`backend listening on ${port}`);
});
EOF

