{
  "name": "opencommons-health-pim",
  "version": "0.1.0",
  "description": "OpenCommons Health – Personal Information Management application backed by a local Solid Community Server pod",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "solid",
    "solid-pod",
    "solid-community-server",
    "health",
    "personal-information-management",
    "linked-data",
    "rdf",
    "shex"
  ],
  "author": "OpenCommons Health Contributors",
  "license": "MIT",
  "dependencies": {
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-node": "^5.0.0",
    "@rdfjs/types": "^2.0.1",
    "n3": "^1.23.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/n3": "^1.21.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
